# Copy to .env.local for local dev (and set in compose `environment` for Docker).
# No secrets live here — Cofield's MVP has no server-side keys.

# WebSocket URL the browser connects to for realtime sync.
# Local dev:        ws://localhost:4321
# docker compose:   ws://localhost:4321  (the sync service publishes this port)
# Production:       wss://sync.your-host.example
NEXT_PUBLIC_WS_URL=ws://localhost:4321

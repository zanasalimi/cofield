{
  "name": "cofield",
  "version": "0.1.0",
  "private": true,
  "description": "Infinite collaborative canvas — multiple teams editing the same board in real time on CRDTs, with live cursors, presence, and offline-safe merge.",
  "license": "MIT",
  "author": "Zana Salimi",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "tsx server/index.ts",
    "sync:build": "tsc -p tsconfig.server.json",
    "format": "prettier --write .",
    "docker:web": "docker build -f Dockerfile.web -t cofield-web .",
    "docker:sync": "docker build -f Dockerfile.sync -t cofield-sync .",
    "docker:up": "docker compose up"
  },
  "dependencies": {
    "@embertoast/react": "^0.1.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "better-sqlite3": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "drizzle-orm": "^0.45.2",
    "lib0": "^0.2.99",
    "lucide-react": "^1.18.0",
    "next": "^15.1.3",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.0",
    "y-indexeddb": "^9.0.12",
    "y-leveldb": "^0.1.2",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.21",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

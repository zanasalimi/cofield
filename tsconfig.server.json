{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "outDir": "dist/server",
    "rootDir": ".",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/**/*.ts", "src/collab/types.ts"],
  "exclude": ["node_modules"]
}
